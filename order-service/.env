# Order Service Environment Variables
HTTP_PORT=8080
GRPC_PORT=50052

# gRPC address of the Payment Service (no hardcoded values in source code)
PAYMENT_SERVICE_ADDR=localhost:50051

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=orders_db
DB_SSLMODE=disable
